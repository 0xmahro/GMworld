# GM World - add these to .env.local

# App URL (for Base/Farcaster manifest, OG images)
NEXT_PUBLIC_APP_URL=https://worldgm.xyz

# Supabase (https://supabase.com/dashboard)
NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key

# WalletConnect Project ID from https://cloud.walletconnect.com
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_project_id

# GMWorldV2 contract (after deploy) - fee recipient = deployer
NEXT_PUBLIC_GMWORLD_ADDRESS=0x...

# Base Mini App - Account association (from https://base.dev/preview)
# FC_ACCOUNT_HEADER=
# FC_ACCOUNT_PAYLOAD=
# FC_ACCOUNT_SIGNATURE=

# Neynar Sign in with Farcaster (optional)
# NEXT_PUBLIC_NEYNAR_CLIENT_ID=
# NEYNAR_API_KEY=
